# TDPortal-OS Environment Configuration
# Copy this to .env and customize

# ── Application ──────────────────────────────────────────────────
APP_NAME=TDPortal-OS
APP_VERSION=1.0.0
DEBUG=false

# ── Database ─────────────────────────────────────────────────────
# Default: SQLite (no additional setup needed)
DATABASE_URL=sqlite:////data/tdportal.db
# PostgreSQL (optional — requires postgres service):
# DATABASE_URL=postgresql://tdportal:tdportal@postgres:5432/tdportal

# ── Redis / Celery ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Storage ──────────────────────────────────────────────────────
DATA_DIR=/data
UPLOAD_DIR=/data/uploads
JOB_DIR=/data/jobs

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost"]

# ── Demo Mode ────────────────────────────────────────────────────
# IMPORTANT: Demo results are synthetic. Set to false for production use.
DEMO_MODE_ENABLED=true

# ── Engine Binaries (optional — leave blank to use PATH lookup) ──
# TOPFD_BIN=/opt/toppic-suite/bin/topfd
# TOPPIC_BIN=/opt/toppic-suite/bin/toppic
# TOPMG_BIN=/opt/toppic-suite/bin/topmg
# MSPATHFINDER_BIN=/opt/informed-proteomics/MSPathFinderT
# FLASHDECONV_BIN=/opt/openms/bin/FLASHDeconv

# ── Docker Build Args ────────────────────────────────────────────
# Set to 1 to attempt TopPIC Suite installation during Docker build
INSTALL_TOPPIC=0

# ── Engine Binary Directories (for Docker volume mounts) ─────────
# TOPPIC_BIN_DIR=/path/to/your/toppic/bin

# ── File Upload Limits ───────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=2048
